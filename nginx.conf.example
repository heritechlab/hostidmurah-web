# Nginx config untuk hostidmurah.web.id
# Salin ke: /etc/nginx/sites-available/hostidmurah-web
# Lalu: sudo ln -s /etc/nginx/sites-available/hostidmurah-web /etc/nginx/sites-enabled/
# Lalu: sudo nginx -t && sudo systemctl reload nginx

server {
    listen 80;
    server_name hostidmurah.web.id www.hostidmurah.web.id;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name hostidmurah.web.id www.hostidmurah.web.id;

    ssl_certificate     /etc/letsencrypt/live/hostidmurah.web.id/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/hostidmurah.web.id/privkey.pem;

    # Gzip
    gzip on;
    gzip_types text/plain text/css application/json application/javascript text/javascript;

    # Next.js static files
    location /_next/static/ {
        alias /var/www/hostidmurah-web/.next/static/;
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    # Public folder
    location /public/ {
        alias /var/www/hostidmurah-web/public/;
    }

    # Backend API — proxy ke FastAPI (port 8000)
    location /api/ {
        proxy_pass         http://127.0.0.1:8000/api/;
        proxy_http_version 1.1;
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }

    # Next.js app — proxy ke port 3000
    location / {
        proxy_pass         http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade $http_upgrade;
        proxy_set_header   Connection "upgrade";
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }
}
